# Desktop UI Environment Variables

# PWA Configuration
# Set to 'true' to enable PWA features (service worker, offline support)
# Default: enabled in production, disabled in development
REACT_APP_ENABLE_PWA=false

# Performance Monitoring
# Set to 'true' to enable Web Vitals logging in development
REACT_APP_ENABLE_VITALS_LOGGING=true

# Bundle Analysis
# Set to 'true' when building to generate bundle size report
# Usage: ANALYZE=true npm run build
# ANALYZE=false

# Micro-Frontends: Analytics remote URL (default: http://localhost:3002)
# REACT_APP_ANALYTICS_REMOTE_URL=http://localhost:3002
