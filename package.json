{
  "name": "desktop-ui",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.6",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.101",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "lucide-react": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.4.4",
    "react-hook-form": "^7.71.2",
    "react-redux": "^9.1.2",
    "react-scripts": "5.0.1",
    "uuid": "^10.0.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-app-rewired start",
    "build": "react-app-rewired build",
    "build:vercel": "react-app-rewired build && ./scripts/verify-remote-entry-build.sh",
    "build:analyze": "ANALYZE=true react-app-rewired build",
    "test": "react-app-rewired test",
    "test:unit": "react-scripts test --watchAll=false",
    "test:e2e": "playwright test",
    "test:memory": "playwright test --config=playwright.memory.config.ts",
    "test:memory:forever": "./run-memory-chaos-forever.sh",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:e2e",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "eject": "react-scripts eject",
    "prepare": "husky",
    "host:start": "cd host && npm run start",
    "host:build": "cd host && npm run build",
    "host:deploy:vercel": "./scripts/deploy-host-vercel.sh",
    "host:deploy:vercel:preview": "./scripts/deploy-host-vercel.sh --preview",
    "analytics:start": "cd src/features/remotes/analytics && npm run start",
    "analytics:build": "cd src/features/remotes/analytics && npm run build",
    "mf:demo": "npm run build && npx serve -s build -l 3000"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "jest": {
    "moduleNameMapper": {
      "^~/(.*)$": "<rootDir>/src/$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.[jt]s?(x)",
      "**/?(*.)test.[jt]s?(x)"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@playwright/test": "^1.49.0",
    "@testing-library/react": "^14.2.0",
    "@types/react-grid-layout": "^1.3.5",
    "@types/uuid": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.49.0",
    "prettier": "^3.8.1",
    "react-app-rewired": "^2.2.1",
    "serve": "^14.2.5",
    "typescript": "^5.9.3",
    "webpack-bundle-analyzer": "^5.2.0",
    "workbox-webpack-plugin": "^7.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json}": [
      "prettier --write"
    ]
  }
}
